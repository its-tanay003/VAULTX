{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vaultx",
  "compatibility_date": "2026-06-18",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "build": {
    "command": "npx opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion"
  }
}
