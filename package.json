{
  "name": "vaultx",
  "version": "0.1.0",
  "private": true,
  "description": "AI-first, zero-infrastructure-cost cybersecurity and code intelligence platform.",
  "author": "Tanay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/its-tanay003/VAULTX.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion",
    "build-next": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lighthouse": "lhci autorun",
    "check-bundle-size": "node scripts/check-bundle-size.js",
    "deploy": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build --dangerouslyUseUnsupportedNextVersion && opennextjs-cloudflare preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.44.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.3.2",
    "geist": "^1.3.1",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^9.1.0",
    "recharts": "^2.12.7",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.5.0",
    "stripe": "^16.2.0",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.4.38",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10",
    "wait-on": "^7.2.0",
    "wrangler": "^4.110.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "node ./node_modules/eslint/bin/eslint.js --fix"
    ]
  }
}
