# ==============================================================================
# VAULTX — Master Environment Variables Example (.env.example)
# Consolidates all environment variables for the platform (Weeks 1-11)
# ==============================================================================

# ── Supabase Setup ────────────────────────────────────────────────────────────
# Retrieve from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE   # NEVER expose to client (no NEXT_PUBLIC_ prefix)

# ── App Domain ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000               # Change to production domain (e.g. https://your-app.pages.dev) before deploying

# ── Resend Email Infrastructure ───────────────────────────────────────────────
# Register at: https://resend.com
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=noreply@yourdomain.com                # Use onboarding@resend.dev for testing without verified domain

# ── Upstash Redis Rate Limiting ───────────────────────────────────────────────
# Retrieve from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR_ENDPOINT.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN_HERE

# ── Web Push (VAPID) ───────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# Public key is exposed to the browser (NEXT_PUBLIC_), private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:support@yourdomain.com

# ── AI Orchestration (Primary + Fallback) ──────────────────────────────────────
# Primary: Anthropic Claude (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Fallback: Google Gemini (https://aistudio.google.com)
GEMINI_API_KEY=AIzaSyYOUR_KEY_HERE

# Internal webhook secret (generate with: openssl rand -hex 32)
VAULT_INTERNAL_SECRET=your-random-32-char-secret-here

# ── Demo Seeding ──────────────────────────────────────────────────────────────
# Local seeding only. Specify the organization owner email.
DEMO_ORG_OWNER_EMAIL=you@email.com

# ── Stripe Payouts (Future Integration) ───────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
